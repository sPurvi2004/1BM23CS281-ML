      "source": [
        "### Simplified K-Means Implementation\n",
        "\n",
        "This version combines the steps into a single function for a more concise approach."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "fdb8ed30"
      },
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "def simple_kmeans(data, k, max_iterations=100):\n",
        "    data_np = data.values\n",
        "\n",
        "    # 1. Initialization: Randomly select k data points as initial centroids\n",
        "    indices = np.random.choice(len(data_np), k, replace=False)\n",
        "    centroids = data_np[indices]\n",
        "\n",
        "    for i in range(max_iterations):\n",
        "        # 2. Assignment: Assign each data point to the nearest centroid\n",
        "        distances = np.sqrt(((data_np - centroids[:, np.newaxis])**2).sum(axis=2))\n",
        "        assignments = np.argmin(distances, axis=0)\n",
        "\n",
        "        # 3. Update: Recalculate the centroids\n",
        "        new_centroids = np.array([data_np[assignments == j].mean(axis=0) for j in range(k)])\n",
        "\n",
        "        # Check for convergence\n",
        "        if np.allclose(centroids, new_centroids):\n",
        "            break\n",
        "\n",
        "        centroids = new_centroids\n",
        "\n",
        "    return assignments, centroids\n",
        "\n",
        "print(\"Simplified K-Means function defined.\")"
      ],
      "execution_count": null,
      "outputs": []
    },
